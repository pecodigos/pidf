{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PiDF",
  "version": "0.1.0",
  "identifier": "com.pepe.pidf",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "PiDF",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:*; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; font-src 'self' data:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/pidf-render-cache/**",
          "$TEMP/pidf-render-cache/**",
          "$TMP/pidf-render-cache/**",
          "/tmp/pidf-render-cache/**",
          "/var/tmp/pidf-render-cache/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
